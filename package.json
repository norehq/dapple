{
  "name": "dapple-workspace",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "pnpm --filter @unix/dapple-preview dev",
    "build": "pnpm -r build",
    "preview:build": "pnpm --filter @unix/dapple-preview build",
    "preview:deploy": "pnpm preview:build && pnpm --dir packages/preview exec wrangler deploy --config wrangler.jsonc",
    "preview:dry-run": "pnpm preview:build && pnpm --dir packages/preview exec wrangler deploy --config wrangler.jsonc --dry-run",
    "format": "prettier --write .",
    "release": "pnpm --filter @unix/dapple build && pnpm --filter @unix/dapple publish --access public --no-git-checks",
    "typecheck": "pnpm -r typecheck"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unix/dapple"
  },
  "prettier": "@unix/prettier",
  "devDependencies": {
    "@unix/prettier": "^0.1.0",
    "prettier": "^3.8.3",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "wrangler": "^4.97.0"
  }
}
