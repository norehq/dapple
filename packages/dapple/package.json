{
  "name": "@unix/dapple",
  "version": "0.2.1",
  "description": "A small WebGL dapple renderer for images.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./field": {
      "types": "./dist/field.d.ts",
      "import": "./dist/field.js",
      "require": "./dist/field.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./react-field": {
      "types": "./dist/react-field.d.ts",
      "import": "./dist/react-field.js",
      "require": "./dist/react-field.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@unix/prettier",
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@unix/prettier": "^0.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
