{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@norehq/dapple": ["../../packages/dapple/src/index.ts"],
      "@norehq/dapple/field": ["../../packages/dapple/src/field.ts"],
      "@norehq/dapple/react": ["../../packages/dapple/src/react.tsx"],
      "@norehq/dapple/react-field": ["../../packages/dapple/src/react-field.tsx"],
      "components": ["./src/components"],
      "components/*": ["./src/components/*"],
      "hooks": ["./src/hooks"],
      "hooks/*": ["./src/hooks/*"],
      "lib": ["./src/lib"],
      "lib/*": ["./src/lib/*"],
      "ui": ["./src/components/ui"],
      "ui/*": ["./src/components/ui/*"],
      "utils": ["./src/lib/utils"],
      "utils/*": ["./src/lib/utils/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
