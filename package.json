{
  "name": "dapple-workspace",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "pnpm --filter @norehq/dapple-preview dev",
    "build": "pnpm -r build",
    "cf:preview:build": "pnpm --filter @norehq/dapple-preview build",
    "cf:preview:deploy": "pnpm cf:preview:build && wrangler deploy",
    "cf:preview:dry-run": "pnpm cf:preview:build && wrangler deploy --dry-run",
    "format": "prettier --write .",
    "release": "pnpm --filter @norehq/dapple build && pnpm --filter @norehq/dapple publish --access public --no-git-checks",
    "typecheck": "pnpm -r typecheck"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/norehq/dapple"
  },
  "prettier": "@norehq/prettier",
  "devDependencies": {
    "@norehq/prettier": "^0.1.0",
    "prettier": "^3.8.3",
    "tslib": "^2.8.1",
    "typescript": "~6.0.2",
    "wrangler": "^4.95.0"
  }
}
